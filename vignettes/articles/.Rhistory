code <- "
#include <Rcpp.h>
using namespace Rcpp;
inline bool rcpp_int_in(
const int needle, const SEXP haystack, const R_xlen_t startpos, const R_xlen_t endpos
) {
const int *phay = INTEGER_RO(haystack);
for(R_xlen_t i = startpos; i <= endpos; ++i) {
if(needle == phay[i - 1]) {
return true;
}
}
return false;
}
//' @keywords internal
//' @noRd
// [[Rcpp::export(rcpp_invert_indices_int)]]
SEXP rcpp_invert_indices_int(
SEXP ind, R_xlen_t dimsize
) {
const int *pind = INTEGER_RO(ind);
R_xlen_t ind_len = Rf_xlength(ind);
R_xlen_t out_len = dimsize - ind_len;
SEXP out = PROTECT(Rf_allocVector(INTSXP, out_len));
int *pout = INTEGER(out);
const R_xlen_t ind_min = INTEGER_ELT(ind, 0);
const R_xlen_t ind_max = INTEGER_ELT(ind, ind_len - 1);
R_xlen_t counter = 0;
if(ind_min > 1) {
for(R_xlen_t i = 1; i < ind_min; ++i) {
pout[counter] = i;
counter++;
}
}
R_xlen_t startpos = 1;
const R_xlen_t endpos = ind_len;
for(R_xlen_t i = (ind_min + 1); i < ind_max; ++i) {
if(!rcpp_int_in(i, ind, startpos, endpos)) {
pout[counter] = i;
startpos++;
counter++;
}
}
if(ind_max < dimsize) {
for(R_xlen_t i = (ind_max + 1); i <= dimsize; ++i) {
pout[counter] = i;
counter++;
}
}
UNPROTECT(1);
return out;
}
"
Rcpp::sourceCpp(code = code)
n <- 1e6
x <- sample(1:1e6)
ind <- 10:(n - 10)
x[-ind]
x[seq_len(100L)[-ind]]
n <- 1e5
x <- sample(1:1e5)
ind <- 10:(n - 10)
rcpp_invert_indices_int(ind, n)
collapse::funique(ind, sort = TRUE)
n <- 1e4
x <- sample(1:n)
ind <- 10:(n - 10)
rcpp_invert_indices_int(ind, n)
foo <- bench::mark(
base = x[-ind],
sb = x[seq_len(100L)[-ind]],
rcpp = x[rcpp_invert_indices_int(ind, n)],
clp_rcpp = x[collapse::funique(ind, sort = TRUE) |> rcpp_invert_indices_int(n)],
min_iterations = 100
)
foo <- bench::mark(
base = x[-ind],
sb = x[seq_len(n)[-ind]],
rcpp = x[rcpp_invert_indices_int(ind, n)],
clp_rcpp = x[collapse::funique(ind, sort = TRUE) |> rcpp_invert_indices_int(n)],
min_iterations = 100
)
summary(foo)
plot(foo)
