get_element_by <- function(i, start, stop, by) {
start + i * by
}
get_element_p <- function(i, start, stop, by, which) {
n.tiles.past <- floor((i - 1)/length(which))
j <- i - n.tiles.past * length(which)
start + n.tiles.past * by + (which[j] - 1)
}
sapply(ind, get_element_p, start = 2, stop = 40, by = 4, which = c(1,4))
ind <- sample(1:length(y))
