sapply(ind, get_element_p, start = 2, stop = 40, by = 4, which = c(1,4))
tinytest::expect_equal(
y[ind],
sapply(ind, get_element_p, start = 2, stop = 40, by = 4, which = c(1,4))
)
get_element_by <- function(i, start, stop, by) {
start + i * by
}
get_element_p <- function(i, start, stop, by, Cwhich, lenwhich) {
n.tiles.past <- floor((i - 1) / lenwhich)
j <- i - n.tiles.past * lenwhich
start + n.tiles.past * by + (Cwhich[j])
}
x <- seq(2, 20, 3)
x[3]
get_element(3, 2, 20, 2)
y <- (2:40)[c(TRUE, FALSE, FALSE, TRUE)]
ind <- sample(1:length(y))
tinytest::expect_equal(
y[ind],
sapply(ind, get_element_p, start = 2, stop = 40, by = 4, Cwhich = c(1,4) -1, lenwhich = 2)
)
