header_for_source <- "
#include <Rcpp.h>
using namespace Rcpp;
#define MACRO_SET_ATOMIC(POINTER, INDEX, REPLACEMENT) do {  \\
POINTER[INDEX] = REPLACEMENT; \\
} while(0)
"
ptrn <- c(TRUE, FALSE, FALSE, TRUE, FALSE)
# 1. Vind de posities van de TRUE's binnen één volledige cyclus
posities <- which(ptrn)
# 2. Bereken de verschillen tussen opeenvolgende posities
# Gebruik de lengte van de vector om de sprong naar de volgende cyclus mee te tellen
stappen <- diff(c(posities, posities[1] + length(ptrn)))
stappen
