ss_x(x, ~ 1:2
)
f <- ~ 1:2
is.formula(f)
tci_formula(1:10, 0, f, sys.call())
rlang::last_trace()
keywords <- list(
.M = m,
.Nms = if(m == 0L) names(x) else dimnames(x)[[m]],
.N = s(x, m),
.I = seq_len(s(x, m)),
.bi = \(...) .internal_bi(list(...),  s(x, m)),
.x = x
)
m = 0
keywords <- list(
.M = m,
.Nms = if(m == 0L) names(x) else dimnames(x)[[m]],
.N = s(x, m),
.I = seq_len(s(x, m)),
.bi = \(...) .internal_bi(list(...),  s(x, m)),
.x = x
)
.with_array(x, keywords, f, sys.call())
